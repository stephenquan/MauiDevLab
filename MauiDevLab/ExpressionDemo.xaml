<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiDevLab.ExpressionDemo"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiDevLab"
    x:Name="demo"
    Title="Expression Demo"
    x:DataType="local:ExpressionDemo">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="FormInputTemplate" TargetType="ContentView">
                <Setter Property="ControlTemplate">
                    <Setter.Value>
                        <ControlTemplate x:DataType="local:FormControlInfo">
                            <Entry Style="{StaticResource FormInput}" Text="{Binding Node.Value, Mode=TwoWay}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="FormNoteTemplate" TargetType="ContentView">
                <Setter Property="ControlTemplate">
                    <Setter.Value>
                        <ControlTemplate x:DataType="local:FormControlInfo">
                            <Entry Style="{StaticResource FormNote}" Text="{Binding Node.Value, Mode=OneWay}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

