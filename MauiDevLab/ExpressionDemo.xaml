<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiDevLab.ExpressionDemo"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiDevLab"
    x:Name="demo"
    Title="Expression Demo"
    x:DataType="local:ExpressionDemo">
    <CollectionView ItemsSource="{Binding FormControls}">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="local:FormControlInfo">
                <Grid Padding="5">
                    <VerticalStackLayout Padding="5" Spacing="5">
                        <Label Style="{StaticResource FormLabel}" Text="{Binding Label}" />
                        <Label Style="{StaticResource FormHint}" Text="{Binding Hint}" />
                        <local:FormControl />
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
