<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiDevLab.JintDemo"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiDevLab"
    Title="Jint Demo"
    x:DataType="local:JintDemo">
    <Grid RowDefinitions="Auto,*">
        <Grid Padding="30,5">
            <Button Command="{Binding RunCommand}" Text="Run" />
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="*,*">
            <Grid Padding="30,5">
                <ScrollView>
                    <Editor AutoSize="TextChanges" Text="{Binding ScriptText, Mode=TwoWay}" />
                </ScrollView>
            </Grid>
            <Grid Grid.Column="1" Padding="30,5">
                <ScrollView>
                    <Editor
                        AutoSize="TextChanges"
                        IsReadOnly="True"
                        Text="{Binding ResultText}" />
                </ScrollView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
